#!/bin/sh
# Dispensing -9 to lousy bastards in need of permanent rest since 1968.
# Options:
# -a to run 'killall' instead of 'kill'
# -s VALUE to send a specific signal

set -e

# A simple wrapper around bemenu. Should probably make it a separate script.
spawn_menu()
{
    printf "%s" "$1" | bemenu --prompt "$2" --list 20
}

# Get all processes in the userspace, and return them in the following format:
# PID process_name
get_processes_except_current_pgid()
{
    current_pgid=$(ps -p $$ -o pgid= | tr -d ' ')
    processes=$(ps -u "$USER" -o pgid=,pid=,args= |
                    awk -v pgid="$current_pgid" '$1 != pgid {print $2, $3}' |
                    sed 's|\([0-9]\+\) .*/|\1 |' | # strip paths
                    tac)
    echo "$processes"
}

# Define $kill_command and $kill_signal either from commandline options
# or, if they weren't specified, by prompting the user in a menu.
choose_kill_command_and_signal()
{
    kill_command=''
    kill_signal=''
    while getopts "aks:" opt; do
        case "$opt" in
            a) kill_command='killall' ;;
            k) kill_command='kill' ;;
            s) kill_signal="$OPTARG" ;;
            *) ;;
        esac
    done

    if [ -z "$kill_command" ]; then
        options=$(printf '%s\n%s' 'kill' 'killall')
        kill_command=$(spawn_menu "$options" 'Select a command:')
    fi

    if [ -z "$kill_signal" ]; then
        options=$(printf '%s -9 (SIGKILL)\n%s -15 (SIGTERM)' \
                         "$kill_command" "$kill_command")
        user_response=$(spawn_menu "$options" 'How would you like to kill?')
        kill_signal=$(echo "$user_response" | awk '{print $2}')
        kill_signal="${kill_signal#?}"
    fi
}

main()
{
    choose_kill_command_and_signal "$@"

    processes=$(get_processes_except_current_pgid)
    prompt=''
    if [ $kill_command = 'killall' ]; then
        # Filter duplicates since we're killing all instances
        processes=$(echo "$processes" | awk '!seen[$2]++')
        prompt="Select a process to kill all instances of (-$kill_signal):"
    else
        prompt="Select a process to kill (-$kill_signal):"
    fi

    process_chosen=$(spawn_menu "$processes" "$prompt")
    process_pid=$(echo "$process_chosen" | awk '{print $1}')
    process_name=$(echo "$process_chosen" | awk '{print $2}')

    if [ "$kill_command" = 'kill' ]; then
        # Kill a single process
        $kill_command "-$kill_signal" "$process_pid"
    else
        # Kill all instances
        $kill_command "-$kill_signal" "$process_name"
    fi
}

main "$@"
