#!/bin/sh

colors='bg0       #282828
bg0_h     #1d2021
bg0_s     #32302f
bg1       #3c3836
bg2       #504945
bg3       #665c54
bg4       #7c6f64
fg0       #fbf1c7
fg1       #ebdbb2
fg2       #d5c4a1
fg3       #bdae93
fg4       #a89984
black_b   #928374
red_b     #fb4934
green_b   #b8bb26
yellow_b  #fabd2f
blue_b    #83a598
purble_b  #d3869b
aqua_b    #8ec07c
white_b   #ebdbb2
orange    #d65d0e
orange_b  #fe8019
gray      #928374
black     #282828
red       #cc241d
green     #98971a
yellow    #d79921
blue      #458588
purple    #b16286
aqua      #689d6a
white     #a89984
'

spawn_menu()
{
    printf '%s' "$1" | bemenu --prompt "$2" --list 10
}

main()
{
    color_chosen=$(spawn_menu "$colors" "Choose a color:")
    set -- $color_chosen
    wl-copy "$2"
}

main "$@"
